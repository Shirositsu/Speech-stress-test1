{
  "buildCommand": "true",
  "outputDirectory": ".",
  "public": true,
  "env": {
    "VERCEL_ANALYTICS_ID": "@optional"
  },
  "routes": [
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
